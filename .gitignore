# ============================================================
# Xayr — .gitignore
# ============================================================

# ---- Secrets / environment ----
# NEVER commit real secrets. Only *.example files are tracked.
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ---- Dependencies ----
/node_modules
/.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js ----
/.next/
/out/
next-env.d.ts

# ---- Production build ----
/build
/dist

# ---- Vercel ----
.vercel

# ---- TypeScript ----
*.tsbuildinfo

# ---- Testing / coverage ----
/coverage

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# ---- Caches ----
.cache
.eslintcache
.turbo

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.pem
*.key
*.p12
*.pfx
*~
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
