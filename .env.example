# ============================================================
# Xayr — Environment variables TEMPLATE
# Copy to .env.local and fill with real values. NEVER commit .env.local.
# Values below are placeholders only — no real secrets.
# ============================================================

# ---- Supabase ----
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SECRET — server only. Bypasses Row Level Security. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-domain.example

# ---- Click payment gateway (SECRET — server only) ----
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key

# ---- Payme payment gateway (SECRET — server only) ----
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# ---- OneSignal browser push ----
# App ID is public (the browser SDK needs it). Create an app at
# https://dashboard.onesignal.com (Web platform) and copy these.
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# SECRET — server only. Used by /api/push/notify to send pushes. Never NEXT_PUBLIC_*.
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# SECRET — server only. Shared secret the Supabase Database Webhook sends as the
# `x-webhook-secret` header so /api/push/notify can authenticate the call.
SUPABASE_WEBHOOK_SECRET=generate-a-long-random-string

# ---- Upstash Redis (rate limiting — SECRET, server only) ----
# Create a database at https://console.upstash.com/redis and copy the
# REST URL + token. If either is missing, rate limiting fails OPEN (allows
# requests) so local dev still works — set both in production.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
