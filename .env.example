# ============================================================
# Xayr — Environment variables TEMPLATE
# Copy to .env.local and fill with real values. NEVER commit .env.local.
# Values below are placeholders only — no real secrets.
# ============================================================

# ---- Supabase ----
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SECRET — server only. Bypasses Row Level Security. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-domain.example

# ---- Click payment gateway (SECRET — server only) ----
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key
# Opt-in: pay by card in-page via Click's checkout.js instead of redirecting.
# Leave unset (default) to keep the proven redirect for every donor; set to 1
# only once validated against a real merchant. Not a secret — a boolean toggle.
# Unset it to roll back instantly. See docs/click-embedded-card.md.
NEXT_PUBLIC_CLICK_EMBEDDED_CARD=
# Click Merchant API user id (SECRET — server only). Enables the reconciliation
# sweep (/api/cron/reconcile-click-payments) that detects card payments captured
# at Click whose donation is still pending and alerts admins (audit F-1). Uses
# the same CLICK_SECRET_KEY. If unset, reconciliation is INERT (no-op) — strongly
# recommended before enabling NEXT_PUBLIC_CLICK_EMBEDDED_CARD. See docs/click-embedded-card.md.
CLICK_MERCHANT_USER_ID=

# ---- Saved cards (OPTIONAL — Click Card Token API) ----
# App-layer encryption key for saved Click tokens. 32 bytes, base64. SECRET —
# server only, NEVER NEXT_PUBLIC_*. Generate: `openssl rand -base64 32`.
# Unset ⇒ saved cards are OFF (routes 503, no UI). See PROJECT_STATUS §11.
PAYMENT_TOKEN_ENC_KEY=
# Client toggle for the saved-cards UI on the donation form. Not a secret — a
# boolean. Off by default ⇒ donation form is exactly today's Checkout JS. Only
# enable once CLICK_MERCHANT_USER_ID + PAYMENT_TOKEN_ENC_KEY are set AND the Card
# Token API is confirmed enabled on the merchant account (PROJECT_STATUS §11 Q9).
NEXT_PUBLIC_CLICK_SAVED_CARDS=

# ---- Payme payment gateway (SECRET — server only) ----
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
# Optional: override the hosted checkout base URL (sandbox: https://checkout.test.paycom.uz)
# PAYME_CHECKOUT_URL=https://checkout.paycom.uz

# ---- OneSignal browser push ----
# App ID is public (the browser SDK needs it). Create an app at
# https://dashboard.onesignal.com (Web platform) and copy these.
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# SECRET — server only. Used by /api/push/notify to send pushes. Never NEXT_PUBLIC_*.
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# SECRET — server only. Shared secret the Supabase Database Webhook sends as the
# `x-webhook-secret` header so /api/push/notify can authenticate the call.
SUPABASE_WEBHOOK_SECRET=generate-a-long-random-string

# ---- Vercel Cron (SECRET — server only) ----
# ⚠️ REQUIRED IN PRODUCTION. Gates the scheduled mutation endpoints
# (/api/cron/expire-campaigns, /api/cron/financial-snapshot). Vercel Cron sends
# it automatically as `Authorization: Bearer $CRON_SECRET`.
# If unset in production the cron endpoints FAIL CLOSED (503) — campaigns will
# not auto-expire and daily financial snapshots will not generate. Optional
# locally, so the jobs can be run by hand.
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-a-long-random-string

# ---- Upstash Redis (rate limiting — SECRET, server only) ----
# ⚠️ REQUIRED IN PRODUCTION. Create a database at
# https://console.upstash.com/redis and copy the REST URL + token.
# If either is missing in production, every rate-limited route FAILS CLOSED with
# a 503 configuration error (login, signup, password reset, donations, contact,
# campaign creation, admin, search). Locally, rate limiting is simply disabled
# with a warning so no Upstash account is needed.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ---- Cloudflare Turnstile (bot protection) ----
# Create a widget at https://dash.cloudflare.com → Turnstile and copy the keys.
# Protects register / login / password reset / contact / campaign creation / KYC
# / guest donations.
# Site key is public (the browser widget needs it); if unset the widget is hidden.
# ⚠️ TURNSTILE_SECRET_KEY IS REQUIRED IN PRODUCTION. If it is missing, every
# protected route FAILS CLOSED with a 503 configuration error rather than
# silently accepting unverified requests. Locally, verification is skipped so no
# Cloudflare account is needed.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# SECRET — server only. Used by the server-side siteverify call. Never NEXT_PUBLIC_*.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ---- Sentry (error monitoring) ----
# The DSN is NOT a secret — it is designed to be embedded in the browser bundle.
# With no DSN the SDK is fully inert (no events sent), so this is optional.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional: environment label + perf trace sample rate (0..1).
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Build-time ONLY — for uploading source maps. SECRET: set in CI/Vercel build env,
# never commit and never prefix with NEXT_PUBLIC_. Source-map upload is skipped if absent.
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
